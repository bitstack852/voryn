# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'Voryn' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    # Disable new architecture so legacy RCT_EXPORT_MODULE native modules work.
    :new_arch_enabled => false
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
    )

    # Patch codegen-generated RCTModuleProviders.mm to register VorynCoreModule.
    # RN 0.85 codegen processes the TypeScript spec but does not auto-populate
    # moduleMapping for app-level modules — only for pods with install_modules_dependencies.
    # This hook re-applies the patch on every pod install.
    module_providers_path = File.join(__dir__, 'build/generated/ios/ReactCodegen/RCTModuleProviders.mm')
    if File.exist?(module_providers_path)
      content = File.read(module_providers_path)
      unless content.include?('@"VorynCore"')
        content.gsub!(
          'NSDictionary<NSString *, NSString *> * moduleMapping = @{',
          "NSDictionary<NSString *, NSString *> * moduleMapping = @{\n      @\"VorynCore\": @\"VorynCoreModule\","
        )
        File.write(module_providers_path, content)
        Pod::UI.puts '[VorynCore] Patched RCTModuleProviders.mm — VorynCoreModule registered.'
      end
    else
      Pod::UI.warn '[VorynCore] RCTModuleProviders.mm not found — run pod install again after first codegen pass.'
    end
  end
end
